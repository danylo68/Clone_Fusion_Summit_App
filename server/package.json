{
  "name": "fusion-summit-server",
  "version": "1.0.0",
  "description": "Fusion Summit Capital Markets — NestJS + TypeScript + PostgreSQL",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "seed": "ts-node src/database/seeds/run-seed.ts",
    "migration:run": "typeorm migration:run -d src/config/typeorm.config.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@nestjs/common":           "^11.0.0",
    "@nestjs/config":           "^4.0.0",
    "@nestjs/core":             "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger":          "^11.0.0",
    "@nestjs/typeorm":          "^11.0.0",
    "class-transformer":        "^0.5.1",
    "class-validator":          "^0.14.0",
    "compression":              "^1.7.4",
    "pg":                       "^8.11.5",
    "reflect-metadata":         "^0.1.13",
    "rxjs":                     "^7.8.0",
    "typeorm":                  "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli":       "^11.0.0",
    "@nestjs/testing":   "^11.0.0",
    "@types/compression":"^1.7.2",
    "@types/express":    "^4.17.17",
    "@types/node":       "^20.0.0",
    "@types/pg":         "^8.11.0",
    "ts-node":           "^10.9.1",
    "typescript":        "^5.2.0"
  }
}
